<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvReportTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Report Streetlight Issue"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvPoleId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pole ID: ---"
        android:textSize="18sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Status:"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/rgStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp">

        <RadioButton
            android:id="@+id/rbWorking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Working"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/rbFused"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fused"/>

        <RadioButton
            android:id="@+id/rbBurningDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Burning in Day"/>
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitReport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Submit Report"/>

</LinearLayout>
